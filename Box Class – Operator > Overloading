#include <iostream>
using namespace std;
class Box {
    int volume;
public:
    Box(int v) {
        volume = v;
    }
    bool operator>(Box b) {
        return volume > b.volume;
    }
    void display() {
        cout << "Volume = " << volume << endl;
    }
};
int main() {
    Box b1(100);
    Box b2(200);
    if (b1 > b2)
        cout << "Box1 is greater";
    else
        cout << "Box2 is greater";
    return 0;
}

Output:
Box2 is greater
