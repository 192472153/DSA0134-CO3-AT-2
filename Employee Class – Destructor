#include <iostream>
#include <cstring>
using namespace std;
class Employee {
    char *name;
    float salary;
public:
    Employee(const char *n, float s) {
        name = new char[strlen(n) + 1];
        strcpy(name, n);
        salary = s;
        cout << "Constructor Called\n";
    }
    void display() {
        cout << "Name: " << name
             << " Salary: " << salary << endl;
    }
    ~Employee() {
        delete[] name;
        cout << "Destructor Called\n";
    }
};
int main() {
    Employee e("Sabesh", 50000);
    e.display();
    return 0;
}

Output:
Constructor Called
Name: Sabesh Salary: 50000
Destructor Called
